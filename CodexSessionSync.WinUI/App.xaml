<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="CodexSessionSync.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CodexSessionSync.WinUI">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E8F4F6F8" />
                    <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppInsetBackgroundBrush" Color="#F9FAFB" />
                    <SolidColorBrush x:Key="AppOutputBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="AppOutputForegroundBrush" Color="#101828" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E00F1117" />
                    <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#1B1F2A" />
                    <SolidColorBrush x:Key="AppInsetBackgroundBrush" Color="#242936" />
                    <SolidColorBrush x:Key="AppOutputBackgroundBrush" Color="#111827" />
                    <SolidColorBrush x:Key="AppOutputForegroundBrush" Color="#E5E7EB" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E00F1117" />
                    <SolidColorBrush x:Key="AppCardBackgroundBrush" Color="#1B1F2A" />
                    <SolidColorBrush x:Key="AppInsetBackgroundBrush" Color="#242936" />
                    <SolidColorBrush x:Key="AppOutputBackgroundBrush" Color="#111827" />
                    <SolidColorBrush x:Key="AppOutputForegroundBrush" Color="#E5E7EB" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
