<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CodexSessionSync.Avalonia.MainWindow"
        Title="Codex 会话同步工具"
        Width="1040" Height="780"
        MinWidth="820" MinHeight="620"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">

  <Window.Resources>
    <SolidColorBrush x:Key="RootSurfaceBrush" Color="#E60B1220" />
    <SolidColorBrush x:Key="CardSurfaceBrush" Color="#C8121C2D" />
    <SolidColorBrush x:Key="InsetSurfaceBrush" Color="#111A2B" />
    <SolidColorBrush x:Key="OutputSurfaceBrush" Color="#0A1020" />
    <SolidColorBrush x:Key="OutputInputBrush" Color="#070C16" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#2B3A52" />
    <SolidColorBrush x:Key="BorderBrushStrong" Color="#31435D" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#EEF4FF" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B7C4D8" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#96A6BD" />
    <SolidColorBrush x:Key="ButtonSurfaceBrush" Color="#18253A" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{DynamicResource InsetSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="18,6" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="{DynamicResource ButtonSurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushStrong}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.accent">
      <Setter Property="Background" Value="#2568B6" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#4C8DD4" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#B43229" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#DA6A61" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
      <Setter Property="FontSize" Value="13" />
    </Style>
  </Window.Styles>

  <Panel>
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
          TintColor="#0B1220"
          TintOpacity="0.78"
          FallbackColor="#0B1220" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Border Margin="18"
            CornerRadius="10"
            Background="{DynamicResource RootSurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrushSoft}"
            BorderThickness="1"
            BoxShadow="0 20 48 0 #66000000"
            ClipToBounds="True">
      <Grid Margin="24" RowDefinitions="Auto,16,Auto,16,Auto,16,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Codex 会话同步工具"
                       FontSize="26"
                       FontWeight="SemiBold" />
            <TextBlock Text="默认预览，不会写入；勾选确认后点击执行写入才会修改文件和 SQLite。"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>

          <Button x:Name="ThemeToggleBtn"
                  Grid.Column="1"
                  Content="&#xE706;"
                  Width="36"
                  MinWidth="36"
                  MinHeight="36"
                  Padding="0"
                  Margin="0,0,12,0"
                  Background="Transparent"
                  BorderBrush="Transparent"
                  FontFamily="Segoe Fluent Icons"
                  FontSize="16"
                  ToolTip.Tip="切换到浅色模式" />

          <Border Grid.Column="2"
                  Background="{DynamicResource InsetSurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrushStrong}"
                  BorderThickness="1"
                  CornerRadius="4"
                  Padding="14,8"
                  MinWidth="124"
                  VerticalAlignment="Center">
            <TextBlock x:Name="StatusLabel"
                       Text="准备就绪"
                       FontSize="13"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
          </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource CardSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="6">
              <TextBlock Text="Codex Home"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <TextBox x:Name="CodexHomeBox" />
              <TextBlock Text="默认读取 CODEX_HOME 或当前用户的 .codex。"
                         FontSize="12"
                         Foreground="{DynamicResource MutedTextBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="6">
              <TextBlock Text="备份目录"
                         FontSize="13"
                         FontWeight="SemiBold" />
              <TextBox x:Name="BackupDirBox" />
              <TextBlock Text="执行写入时建议填写，例如桌面上的 codex-backup。"
                         FontSize="12"
                         Foreground="{DynamicResource MutedTextBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="4"
                Background="{DynamicResource CardSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <Grid RowDefinitions="Auto,16,Auto,16,Auto">
            <StackPanel Grid.Row="0" Spacing="10">
              <TextBlock Text="同步模式"
                         FontSize="13"
                         FontWeight="SemiBold" />

              <Grid ColumnDefinitions="*,10,*,10,*">
                <Border Name="PillMutual"
                        Grid.Column="0"
                        Background="#203A5F"
                        BorderBrush="#4C8DD4"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12"
                        Cursor="Hand">
                  <StackPanel Spacing="4">
                    <TextBlock Text="全供应商互同步"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="配置中的每个 provider 最终看到同一批会话。"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Name="PillOpenAi"
                        Grid.Column="2"
                        Background="#111A2B"
                        BorderBrush="#31435D"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12"
                        Cursor="Hand">
                  <StackPanel Spacing="4">
                    <TextBlock Text="OpenAI 同步到全部"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="以 source provider 为源，给其它 provider 创建镜像。"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Border Name="PillMigrate"
                        Grid.Column="4"
                        Background="#111A2B"
                        BorderBrush="#31435D"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="12"
                        Cursor="Hand">
                  <StackPanel Spacing="4">
                    <TextBlock Text="单目标迁移"
                               FontSize="14"
                               FontWeight="SemiBold" />
                    <TextBlock Text="把非保留 provider 的历史会话迁移到目标 provider。"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>

              <RadioButton x:Name="ModeMutual" GroupName="Mode" IsChecked="True" IsVisible="False" />
              <RadioButton x:Name="ModeOpenAi" GroupName="Mode" IsVisible="False" />
              <RadioButton x:Name="ModeMigrate" GroupName="Mode" IsVisible="False" />
            </StackPanel>

            <Grid Grid.Row="2" ColumnDefinitions="*,16,*">
              <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="源 provider"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBox x:Name="SourceProviderBox" Text="openai" />
              </StackPanel>

              <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="目标 provider"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBox x:Name="TargetProviderBox" Text="openai" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,Auto,*,Auto">
              <Button x:Name="PreviewBtn"
                      Grid.Column="0"
                      Content="预览"
                      Classes="accent"
                      Margin="0,0,10,0" />
              <Button x:Name="ApplyBtn"
                      Grid.Column="1"
                      Content="执行写入"
                      Classes="danger"
                      Margin="0,0,10,0" />
              <Button x:Name="DefaultsBtn"
                      Grid.Column="2"
                      Content="恢复默认路径"
                      Margin="0,0,10,0" />
              <CheckBox x:Name="ConfirmCheck"
                        Grid.Column="4"
                        Content="我已备份或确认可以写入"
                        VerticalAlignment="Center" />
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="6"
                Background="{DynamicResource OutputSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                MinHeight="120"
                VerticalAlignment="Stretch">
          <Grid RowDefinitions="Auto,10,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="运行输出"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="报告会区分需创建、已存在、过期跳过和冲突。"
                           FontSize="12"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Border Grid.Column="1"
                      Background="{DynamicResource InsetSurfaceBrush}"
                      CornerRadius="999"
                      Padding="10,5"
                      VerticalAlignment="Center">
                <TextBlock Text="LOG"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
              </Border>
            </Grid>

            <TextBox Grid.Row="2"
                     x:Name="OutputBox"
                     MinHeight="0"
                     Background="{DynamicResource OutputInputBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     FontFamily="Cascadia Code,Consolas,monospace"
                     FontSize="13"
                     BorderBrush="{DynamicResource BorderBrushSoft}"
                     BorderThickness="1"
                     CornerRadius="6"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Text="等待运行。" />
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Panel>
</Window>
