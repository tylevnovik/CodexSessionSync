<wnd:AppWindow xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:ui="using:FluentAvalonia.UI.Controls"
               xmlns:wnd="using:FluentAvalonia.UI.Windowing"
               x:Class="CodexSessionSync.Avalonia.MainWindow"
               Title="Codex 会话同步工具"
               Width="1080"
               Height="780"
               MinWidth="860"
               MinHeight="640"
               TransparencyLevelHint="Mica"
               TransparencyBackgroundFallback="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
               Background="Transparent">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
  <Grid Margin="28,22,28,28"
        RowDefinitions="Auto,18,Auto,18,Auto,18,Auto"
        MaxWidth="1100"
        HorizontalAlignment="Stretch">

    <Grid Grid.Row="0"
          ColumnDefinitions="*,Auto"
          MinHeight="64">
      <StackPanel Grid.Column="0"
                  Spacing="4"
                  VerticalAlignment="Center">
        <TextBlock Text="Codex 会话同步工具"
                   FontSize="30"
                   FontWeight="SemiBold" />
        <TextBlock Text="先预览计划，确认后再允许写入 JSONL 和 SQLite。"
                   Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Button x:Name="ThemeToggleBtn"
              Grid.Column="1"
              VerticalAlignment="Top"
              Padding="12,6"
              ToolTip.Tip="切换到浅色模式">
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <ui:SymbolIcon x:Name="ThemeToggleIcon"
                         Symbol="WeatherSunny"
                         FontSize="16" />
          <TextBlock x:Name="ThemeToggleLabel"
                     Text="浅色模式" />
        </StackPanel>
      </Button>
    </Grid>

    <ui:InfoBar x:Name="StatusInfoBar"
                Grid.Row="2"
                Title="准备就绪"
                Message="默认只预览，不会写入；开启写入确认后再执行。"
                Severity="Informational"
                IsOpen="True"
                IsClosable="False" />

    <ui:SettingsExpander Grid.Row="4"
                         Header="同步设置"
                         Description="路径、模式、provider 和写入确认。"
                         IconSource="Sync"
                         IsExpanded="True">
      <ui:SettingsExpanderItem Content="Codex Home"
                               Description="默认读取 CODEX_HOME，未设置时使用当前用户的 .codex。"
                               IconSource="Home">
        <ui:SettingsExpanderItem.Footer>
          <TextBox x:Name="CodexHomeBox"
                   Width="520"
                   Watermark="Codex Home" />
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>

      <ui:SettingsExpanderItem Content="备份目录"
                               Description="执行写入时建议保留，用来备份 SQLite 和被改动的 JSONL。"
                               IconSource="SaveLocal">
        <ui:SettingsExpanderItem.Footer>
          <TextBox x:Name="BackupDirBox"
                   Width="520"
                   Watermark="备份目录" />
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>

      <ui:SettingsExpanderItem Content="同步模式"
                               Description="全供应商互同步、指定源同步到全部，或迁移到单一目标。"
                               IconSource="ViewAll">
        <ui:SettingsExpanderItem.Footer>
          <ui:FAComboBox x:Name="ModeBox"
                         Width="300"
                         SelectedIndex="0">
            <ui:FAComboBoxItem Content="全供应商互同步" />
            <ui:FAComboBoxItem Content="OpenAI 同步到全部" />
            <ui:FAComboBoxItem Content="单目标迁移" />
          </ui:FAComboBox>
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>

      <ui:SettingsExpanderItem Content="源 provider"
                               Description="仅在 OpenAI 同步到全部模式中使用，默认 openai。"
                               IconSource="Cloud">
        <ui:SettingsExpanderItem.Footer>
          <TextBox x:Name="SourceProviderBox"
                   Width="300"
                   Text="openai" />
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>

      <ui:SettingsExpanderItem Content="目标 provider"
                               Description="用于单目标迁移模式，默认 openai。"
                               IconSource="ImportAll">
        <ui:SettingsExpanderItem.Footer>
          <TextBox x:Name="TargetProviderBox"
                   Width="300"
                   Text="openai" />
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>

      <ui:SettingsExpanderItem Content="写入确认"
                               Description="关闭时所有执行都保持预览；开启后才允许点击执行写入。"
                               IconSource="ProtectedDocument">
        <ui:SettingsExpanderItem.Footer>
          <ToggleSwitch x:Name="ConfirmToggle"
                        OffContent="仅预览"
                        OnContent="允许写入" />
        </ui:SettingsExpanderItem.Footer>
      </ui:SettingsExpanderItem>
    </ui:SettingsExpander>

    <Grid Grid.Row="6"
          RowDefinitions="Auto,12,*">
      <Grid Grid.Row="0"
            ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Center">
          <ui:SymbolIcon Symbol="Document"
                         FontSize="22" />
          <StackPanel Spacing="2">
            <TextBlock Text="运行输出"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <TextBlock Text="报告会区分需创建、已存在、过期跳过和冲突。"
                       Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
          <Button x:Name="PreviewBtn"
                  MinWidth="116"
                  Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <ui:SymbolIcon Symbol="Preview"
                             FontSize="16" />
              <TextBlock Text="预览" />
            </StackPanel>
          </Button>

          <Button x:Name="ApplyBtn"
                  Classes="accent"
                  MinWidth="132"
                  Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <ui:SymbolIcon Symbol="Important"
                             FontSize="16" />
              <TextBlock Text="执行写入" />
            </StackPanel>
          </Button>

          <Button x:Name="DefaultsBtn"
                  MinWidth="124"
                  Padding="16,8">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
              <ui:SymbolIcon Symbol="Refresh"
                             FontSize="16" />
              <TextBlock Text="默认路径" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <TextBox x:Name="OutputBox"
               Grid.Row="2"
               MinHeight="220"
               FontFamily="Cascadia Code, Consolas, monospace"
               FontSize="13"
               IsReadOnly="True"
               TextWrapping="Wrap"
               AcceptsReturn="True"
               VerticalAlignment="Stretch"
               HorizontalAlignment="Stretch"
               ScrollViewer.VerticalScrollBarVisibility="Auto"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled"
               Text="等待运行。" />
    </Grid>
  </Grid>
  </ScrollViewer>
</wnd:AppWindow>
