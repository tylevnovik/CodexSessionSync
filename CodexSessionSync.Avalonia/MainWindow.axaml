<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CodexSessionSync.Avalonia.MainWindow"
        Title="Codex 会话同步工具"
        Width="960" Height="720"
        MinWidth="640" MinHeight="480"
        Background="#f4f6f8">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <!-- Header -->
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Codex 会话同步工具" FontSize="24" FontWeight="Bold" />
          <TextBlock Text="默认预览，不会写入；勾选确认后点击执行写入才会修改文件和 SQLite。" Foreground="Gray" FontSize="13" TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="8" MinWidth="120" VerticalAlignment="Center">
          <TextBlock x:Name="StatusLabel" Text="准备就绪" HorizontalAlignment="Center" />
        </Border>
      </Grid>

      <!-- Config -->
      <Border BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="16" Background="White">
        <Grid ColumnDefinitions="*,16,*">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Codex Home" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
            <TextBox x:Name="CodexHomeBox" />
            <TextBlock Text="默认读取 CODEX_HOME 或当前用户的 .codex。" FontSize="12" Foreground="#667085" />
          </StackPanel>
          <StackPanel Grid.Column="2" Spacing="4">
            <TextBlock Text="备份目录" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
            <TextBox x:Name="BackupDirBox" />
            <TextBlock Text="执行写入时建议填写，例如桌面上的 codex-backup。" FontSize="12" Foreground="#667085" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- Mode -->
      <Border BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="16" Background="White">
        <StackPanel Spacing="12">
          <TextBlock Text="同步模式" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
          <StackPanel Orientation="Horizontal" Spacing="16">
            <RadioButton x:Name="ModeMutual" Content="全供应商互同步" GroupName="Mode" IsChecked="True" />
            <RadioButton x:Name="ModeOpenAi" Content="OpenAI 同步到全部" GroupName="Mode" />
            <RadioButton x:Name="ModeMigrate" Content="单目标迁移" GroupName="Mode" />
          </StackPanel>
          <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="源 provider" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
              <TextBox x:Name="SourceProviderBox" Text="openai" />
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="4">
              <TextBlock Text="目标 provider" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
              <TextBox x:Name="TargetProviderBox" Text="openai" />
            </StackPanel>
          </Grid>
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button x:Name="PreviewBtn" Content="预览" Background="#344054" Foreground="White" FontWeight="Bold" />
            <Button x:Name="ApplyBtn" Content="执行写入" Background="#b42318" Foreground="White" FontWeight="Bold" />
            <Button x:Name="DefaultsBtn" Content="恢复默认路径" Background="#475467" Foreground="White" FontWeight="Bold" />
            <CheckBox x:Name="ConfirmCheck" Content="我已备份或确认可以写入" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Output -->
      <Border Background="White" BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="12">
        <StackPanel Spacing="8">
          <TextBlock Text="运行输出" FontWeight="Bold" FontSize="13" Foreground="#1d2939" />
          <TextBox x:Name="OutputBox"
                   Background="#f9fafb"
                   Foreground="#1d2939"
                   FontFamily="Consolas"
                   FontSize="13"
                   BorderThickness="1"
                   BorderBrush="#d0d5dd"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   Height="280"
                   Text="等待运行。" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Window>
