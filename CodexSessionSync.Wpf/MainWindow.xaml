<Window x:Class="CodexSessionSync.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex 会话同步工具" Height="720" Width="960"
        MinWidth="640" MinHeight="480"
        Background="#f4f6f8"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Codex 会话同步工具" FontSize="24" FontWeight="Bold" Foreground="#1d2939" Margin="0,0,0,4"/>
                <TextBlock Text="默认预览，不会写入；勾选确认后点击执行写入才会修改文件和 SQLite。" Foreground="#667085" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
            <Border Grid.Column="1" Background="White" BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="12,8" MinWidth="140">
                <TextBlock x:Name="StatusLabel" Text="准备就绪" FontSize="13" Foreground="#475467" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Config -->
        <Border Grid.Row="1" Background="White" BorderBrush="#d9e0e8" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Codex Home" FontWeight="Bold" FontSize="13" Foreground="#344054" Margin="0,0,0,6"/>
                    <TextBox x:Name="CodexHomeBox" Height="36" Padding="8,0" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#cbd5e1"/>
                    <TextBlock Text="默认读取 CODEX_HOME 或当前用户的 .codex。" FontSize="12" Foreground="#667085" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="备份目录" FontWeight="Bold" FontSize="13" Foreground="#344054" Margin="0,0,0,6"/>
                    <TextBox x:Name="BackupDirBox" Height="36" Padding="8,0" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#cbd5e1"/>
                    <TextBlock Text="执行写入时建议填写，例如桌面上的 codex-backup。" FontSize="12" Foreground="#667085" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Mode -->
        <Border Grid.Row="2" Background="White" BorderBrush="#d9e0e8" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="同步模式" FontWeight="Bold" FontSize="13" Foreground="#344054" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <Border Background="#f9fafb" BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,0" MinWidth="220" Cursor="Hand" MouseLeftButtonDown="OnModeCardClick">
                        <RadioButton x:Name="ModeMutual" GroupName="Mode" IsChecked="True" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="全供应商互同步" FontWeight="Bold" FontSize="14" Foreground="#1d2939"/>
                                <TextBlock Text="配置中的每个 provider 最终看到同一批会话。" FontSize="12" Foreground="#667085" TextWrapping="Wrap" MaxWidth="220"/>
                            </StackPanel>
                        </RadioButton>
                    </Border>
                    <Border Background="#f9fafb" BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,8,0" MinWidth="220" Cursor="Hand" MouseLeftButtonDown="OnModeCardClick">
                        <RadioButton x:Name="ModeOpenAi" GroupName="Mode" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="OpenAI 同步到全部" FontWeight="Bold" FontSize="14" Foreground="#1d2939"/>
                                <TextBlock Text="以 source provider 为源，给其它 provider 创建镜像。" FontSize="12" Foreground="#667085" TextWrapping="Wrap" MaxWidth="220"/>
                            </StackPanel>
                        </RadioButton>
                    </Border>
                    <Border Background="#f9fafb" BorderBrush="#d0d5dd" BorderThickness="1" CornerRadius="6" Padding="12" MinWidth="220" Cursor="Hand" MouseLeftButtonDown="OnModeCardClick">
                        <RadioButton x:Name="ModeMigrate" GroupName="Mode" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="单目标迁移" FontWeight="Bold" FontSize="14" Foreground="#1d2939"/>
                                <TextBlock Text="把非保留 provider 的历史会话迁移到目标 provider。" FontSize="12" Foreground="#667085" TextWrapping="Wrap" MaxWidth="220"/>
                            </StackPanel>
                        </RadioButton>
                    </Border>
                </StackPanel>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="源 provider" FontWeight="Bold" FontSize="13" Foreground="#344054" Margin="0,0,0,6"/>
                        <TextBox x:Name="SourceProviderBox" Text="openai" Height="36" Padding="8,0" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#cbd5e1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="目标 provider" FontWeight="Bold" FontSize="13" Foreground="#344054" Margin="0,0,0,6"/>
                        <TextBox x:Name="TargetProviderBox" Text="openai" Height="36" Padding="8,0" VerticalContentAlignment="Center" FontSize="14" BorderBrush="#cbd5e1"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button x:Name="PreviewBtn" Content="预览" Width="90" Height="36" Background="#344054" Foreground="White" FontWeight="Bold" Click="OnPreviewClick" Margin="0,0,8,0"/>
                    <Button x:Name="ApplyBtn" Content="执行写入" Width="100" Height="36" Background="#b42318" Foreground="White" FontWeight="Bold" Click="OnApplyClick" Margin="0,0,8,0"/>
                    <Button Content="恢复默认路径" Height="36" Padding="12,0" Background="#475467" Foreground="White" FontWeight="Bold" Click="OnResetDefaults" Margin="0,0,8,0"/>
                    <CheckBox x:Name="ConfirmCheck" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="我已备份或确认可以写入" FontSize="13" Foreground="#475467"/>
                    </CheckBox>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Output -->
        <Border Grid.Row="5" Background="#101828" CornerRadius="8" Padding="16" Margin="0,0,0,0">
            <TextBox x:Name="OutputBox"
                     Background="Transparent"
                     Foreground="#e4e7ec"
                     FontFamily="Consolas, 'Cascadia Mono', monospace"
                     FontSize="13"
                     BorderThickness="0"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     Text="等待运行。"/>
        </Border>
    </Grid>
</Window>